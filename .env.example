# Database Configuration - Supabase PostgreSQL
PG_USER=postgres
PG_PASSWORD=sua-senha-do-supabase

# Email Configuration - Gmail App Password
# Para obter a senha da app do Gmail:
# 1. Acesse https://myaccount.google.com/security
# 2. Ative 2FA (Autenticação de Dois Fatores)
# 3. Vá para "Senhas de app" e gere uma nova senha para "Mail"
# 4. Copie a senha gerada e configure abaixo

MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app-gmail

# Email From Address
MAIL_FROM=seu-email@gmail.com

# Application Profile: local (padrao) e dev usam HTTPS na porta 8443 — gere certs/dev-keystore.p12 antes
APP_PROFILE=local

# --- Criptografia de Dados em Repouso (Req. 3.4 / 3.6) ---
# Chave AES-256 codificada em Base64 usada para criptografar campos sensíveis no banco.
# NUNCA compartilhe ou versione o valor real desta chave.
# Para gerar uma chave segura, execute:
#   openssl rand -base64 32
ENCRYPTION_KEY=sua-chave-aes-256-em-base64-aqui

# --- HTTPS / TLS (perfil dev — Req. 3.1 / 3.2) ---
# Gere o keystore na raiz do projeto:  bash scripts/generate-dev-keystore.sh
# Opcional: caminho absoluto para outro .p12
# SSL_KEYSTORE_FILE=/caminho/para/meu.p12
SSL_KEYSTORE_PASSWORD=changeit
# Opcional: JDBC completo (PostgreSQL, etc.)
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/db?sslmode=require
# MYSQL_SSL_MODE=REQUIRED
